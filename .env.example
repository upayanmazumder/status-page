# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=statuspage
POSTGRES_USER=statuspage
POSTGRES_PASSWORD=statuspage

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Service URLs (local development)
GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
MONITOR_SERVICE_PORT=4002
NOTIFY_SERVICE_PORT=4003
DASHBOARD_SERVICE_PORT=4004
STATUS_SERVICE_PORT=4005

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=86400

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Frontend
FRONTEND_URL=http://localhost:3000

# SMTP (MailHog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@statuspage.local

# Encryption
ENCRYPTION_KEY=change-me-encryption-key-32-chars!!
